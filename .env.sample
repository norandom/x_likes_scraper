# X account being exported (used by scrape.sh)
X_USERNAME=your_handle
X_USER_ID=000000000
COOKIES_FILE=cookies.json

# MCP server: required. Sign up at https://openrouter.ai
# (the default embedding model is on the free tier).
OPENROUTER_API_KEY=

# MCP server: optional. Only consulted when search_likes is called
# with with_why=true (the walker explainer path).
# OPENAI_BASE_URL=http://localhost:8080/v1
# OPENAI_MODEL=claude-opus-4-1-20250805

# OUTPUT_DIR, OPENROUTER_BASE_URL, EMBEDDING_MODEL, and the RANKER_W_*
# weights all have sensible defaults. See "MCP Server > Configuration"
# in the README if you need to override.
