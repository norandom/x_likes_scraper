# Your X (Twitter) handle, without the @
X_USERNAME=your_handle

# Numeric user ID (NOT the handle).
# Look it up at https://tweeterid.com/ or via the X API.
X_USER_ID=000000000

# Path to your exported cookies (see README for export instructions).
COOKIES_FILE=cookies.json

# Where the export should land. Created if missing.
OUTPUT_DIR=output

# === MCP server (x_likes_mcp) configuration ===
# These are only needed when running `python -m x_likes_mcp`.
# The scrape.sh entry point ignores them.

# Local OpenAI-Chat-Completions-compatible endpoint. The walker (the
# only LLM call site) uses the OpenAI Python SDK; any local gateway
# that speaks /v1/chat/completions works (LiteLLM proxy, vLLM,
# llama.cpp's openai-server, Ollama, etc.). Set it to wherever your
# proxy actually listens.
OPENAI_BASE_URL=http://localhost:8080/v1

# Auth token for the endpoint above. Most local proxies accept anything
# non-empty (e.g. "sk-dummy"); hosted services need a real key.
OPENAI_API_KEY=sk-dummy

# Model name passed to the OpenAI Chat Completions API. Match whatever
# your endpoint expects (e.g. claude-opus-4-1-20250805 if your proxy
# maps OpenAI requests onto an Anthropic-compatible backend).
OPENAI_MODEL=claude-opus-4-1-20250805

# === Ranker weights (Spec 2 / mcp-pageindex) ===
# All optional. Uncomment to override the in-code defaults.
# Final score for a candidate tweet:
#   score =
#     walker_relevance         * W_RELEVANCE
#     + log1p(favorite_count)  * W_FAVORITE
#     + log1p(retweet_count)   * W_RETWEET
#     + log1p(reply_count)     * W_REPLY
#     + log1p(view_count)      * W_VIEW
#     + author_affinity[handle] * W_AFFINITY
#     + recency_decay(created_at, anchor) * W_RECENCY
#     + verified_flag          * W_VERIFIED
#     + has_media_flag         * W_MEDIA
#
# Defaults are intentionally engagement-and-affinity-heavy.
# RANKER_W_RELEVANCE=10.0
# RANKER_W_FAVORITE=2.0
# RANKER_W_RETWEET=2.5
# RANKER_W_REPLY=1.0
# RANKER_W_VIEW=0.5
# RANKER_W_AFFINITY=3.0
# RANKER_W_RECENCY=1.5
# RANKER_W_VERIFIED=0.5
# RANKER_W_MEDIA=0.3
# RANKER_RECENCY_HALFLIFE_DAYS=180
